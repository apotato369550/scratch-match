# App
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# SQLite
DATABASE_URL=file:./data/app.db

# Qdrant (used in later milestones)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Ollama (used in later milestones)
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VERBOSE=true

# Seeded admin (used by scripts/seed-admin.ts)
ADMIN_EMAIL=admin@scratchmatch.local
ADMIN_PASSWORD=changeme

# Limits
MAX_CVS_PER_SPECIALIZATION=5
MAX_OPEN_JOBS_PER_EMPLOYER=5

# RAG (used in later milestones)
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
RAG_TOP_K_JOBS=5
RAG_TOP_K_CVS=3
